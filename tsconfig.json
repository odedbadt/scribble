{
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "Bundler",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "typeRoots": [
      "./types",
      "./node_modules/@types"
    ],
    "target": "ES2020",
    "module": "ESNext",
    "outDir": "./distro",
    "rootDir": "./src/ts",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*" // Include all files in the src directory
  ],
  "exclude": [
    "node_modules",
    "src/ts/old/*.ts"
  ]
}